PORT=5000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/apex

# JWT config
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=30d

# Anthropic API Key for AI features
ANTHROPIC_API_KEY=

# ── OAuth (optional) ─────────────────────────────────────────────────────────
# Google: OAuth 2.0 Web client ID from Google Cloud Console (used to verify the
# ID token audience). Must match VITE_GOOGLE_CLIENT_ID on the client.
GOOGLE_CLIENT_ID=

# Apple: your Services ID (e.g. com.yourapp.web). Comma-separated to allow more
# than one audience (web + native). Must match VITE_APPLE_CLIENT_ID.
APPLE_CLIENT_ID=
