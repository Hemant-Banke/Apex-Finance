# Backend API base URL (defaults to http://localhost:5000/api)
VITE_API_URL=http://localhost:5000/api

# logo.dev publishable token for brand logos in the asset picker (optional)
VITE_LOGODEV_TOKEN=

# ── OAuth (optional) — leave blank to hide that provider's button ────────────
# Google OAuth 2.0 Web client ID (same value as server GOOGLE_CLIENT_ID)
VITE_GOOGLE_CLIENT_ID=

# Apple Services ID (same value as server APPLE_CLIENT_ID)
VITE_APPLE_CLIENT_ID=
# Apple return URL registered for the Services ID; defaults to window.location.origin
VITE_APPLE_REDIRECT_URI=
